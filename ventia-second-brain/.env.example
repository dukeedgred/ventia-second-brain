# Which engine answers "Ask the Brain" questions:
#   cli = local Codex CLI headless (default). No app API key is needed when
#         your local Codex CLI is installed and authenticated.
#   api = hosted API provider seam; not wired in this build.
BRAIN_PROVIDER=cli

# Optional Codex overrides. Leave unset to use your Codex CLI defaults.
# BRAIN_CODEX_MODEL=gpt-5-codex
# BRAIN_CODEX_PROFILE=work

# Port the backend API listens on. Vite dev proxies /api to this.
PORT=8787

# Optional: point the brain at a different content folder (defaults to ./content)
# CONTENT_DIR=C:\path\to\some\other\content
